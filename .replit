modules = ["web", "python-3.12"]
run = "python undefined"

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]

[deployment]
run = ["sh", "-c", "python undefined"]

[[ports]]
localPort = 3000
externalPort = 80
